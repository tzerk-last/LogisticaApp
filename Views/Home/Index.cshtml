@{
    ViewData["Title"] = "LogisticaApp";
    Layout = "_LayoutHome";
}

<div class="min-h-screen bg-gradient-to-br from-indigo-600 to-purple-700">
    <!-- Navbar -->
    <nav class="bg-white/10 backdrop-blur-md shadow-lg">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <h1 class="text-2xl font-bold text-white">LogisticaApp</h1>
            <a href="/Home/Login" class="bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 font-bold">
                Login
            </a>
        </div>
    </nav>

    <!-- Content -->
    <div class="max-w-7xl mx-auto px-4 py-16">
        <div class="text-center mb-16">
            <h2 class="text-5xl font-bold text-white mb-4">Bienvenido a LogisticaApp</h2>
            <p class="text-xl text-white/80">Plataforma integral de logística y entregas</p>
        </div>

        <!-- Roles Cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div class="bg-white rounded-lg shadow-xl p-8 hover:shadow-2xl transition">
                <div class="text-4xl mb-4">👤</div>
                <h3 class="text-xl font-bold text-indigo-600 mb-2">Clientes</h3>
                <p class="text-gray-600 mb-4">Gestiona tus envíos y seguimiento</p>
                <a href="/Home/Login" class="text-indigo-600 font-bold hover:underline">Ingresar →</a>
            </div>

            <div class="bg-white rounded-lg shadow-xl p-8 hover:shadow-2xl transition">
                <div class="text-4xl mb-4">🚗</div>
                <h3 class="text-xl font-bold text-indigo-600 mb-2">Conductores</h3>
                <p class="text-gray-600 mb-4">Administra tus entregas</p>
                <a href="/Home/Login" class="text-indigo-600 font-bold hover:underline">Ingresar →</a>
            </div>

            <div class="bg-white rounded-lg shadow-xl p-8 hover:shadow-2xl transition">
                <div class="text-4xl mb-4">📦</div>
                <h3 class="text-xl font-bold text-indigo-600 mb-2">Operadores</h3>
                <p class="text-gray-600 mb-4">Control logístico total</p>
                <a href="/Home/Login" class="text-indigo-600 font-bold hover:underline">Ingresar →</a>
            </div>

            <div class="bg-white rounded-lg shadow-xl p-8 hover:shadow-2xl transition">
                <div class="text-4xl mb-4">⚙️</div>
                <h3 class="text-xl font-bold text-indigo-600 mb-2">Admin</h3>
                <p class="text-gray-600 mb-4">Panel de administración</p>
                <a href="/Home/Login" class="text-indigo-600 font-bold hover:underline">Ingresar →</a>
            </div>
        </div>
    </div>
</div>
