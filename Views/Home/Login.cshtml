@model LogisticaApp.Models.LoginModel

@{
    ViewData["Title"] = "Login";
    Layout = "_LayoutHome";
}

<div class="min-h-screen bg-gradient-to-br from-indigo-600 to-purple-700 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-2xl p-8 w-full max-w-md">
        <h1 class="text-3xl font-bold text-gray-800 mb-2 text-center">LogisticaApp</h1>
        <p class="text-gray-600 text-center mb-8">Inicia sesión en tu cuenta</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-6">
                @Html.ValidationSummary(false)
            </div>
        }

        <form method="post" action="/Home/Login" class="space-y-6">
            <div>
                <label class="block text-gray-700 font-bold mb-2">Email</label>
                <input type="email" name="Email" 
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600"
                    placeholder="correo@ejemplo.com" required>
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-red-500 text-sm mt-1" })
            </div>

            <div>
                <label class="block text-gray-700 font-bold mb-2">Contraseña</label>
                <input type="password" name="Password" 
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600"
                    placeholder="••••••••" required>
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-red-500 text-sm mt-1" })
            </div>

            <button type="submit" class="w-full bg-indigo-600 text-white font-bold py-2 rounded-lg hover:bg-indigo-700 transition">
                Iniciar Sesión
            </button>
        </form>

        <div class="mt-6 text-center">
            <p class="text-gray-600">¿No tienes cuenta? 
                <a href="/Home/Register" class="text-indigo-600 font-bold hover:underline">Regístrate aquí</a>
            </p>
        </div>

        <!-- Credenciales de prueba -->
        <div class="mt-8 pt-8 border-t border-gray-200">
            <p class="text-sm text-gray-600 font-bold mb-3">Credenciales de prueba:</p>
            <div class="bg-gray-50 p-3 rounded text-sm space-y-2">
                <p><strong>Admin:</strong> admin@logisticaapp.com / Admin123</p>
                <p><strong>Cliente:</strong> cliente@logisticaapp.com / Cliente123</p>
                <p><strong>Conductor:</strong> conductor@logisticaapp.com / Conductor123</p>
            </div>
        </div>
    </div>
</div>
