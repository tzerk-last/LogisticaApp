@{
    ViewData["Title"] = "Dashboard";
    var userRole = ViewBag.UserRole;
    var userName = Context.Session.GetString("UserName");
}

<h2 class="text-3xl font-bold text-gray-800 mb-8">Bienvenido, @userName</h2>

@if (userRole == "Admin")
{
    <!-- ADMIN DASHBOARD -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-indigo-600">
            <h3 class="text-gray-600 text-sm font-bold">Total Usuarios</h3>
            <p class="text-4xl font-bold text-indigo-600">@ViewBag.TotalUsers</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-green-600">
            <h3 class="text-gray-600 text-sm font-bold">Total Envíos</h3>
            <p class="text-4xl font-bold text-green-600">@ViewBag.TotalShipments</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-blue-600">
            <h3 class="text-gray-600 text-sm font-bold">Conductores</h3>
            <p class="text-4xl font-bold text-blue-600">@ViewBag.TotalDrivers</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-purple-600">
            <h3 class="text-gray-600 text-sm font-bold">Rutas</h3>
            <p class="text-4xl font-bold text-purple-600">@ViewBag.TotalRoutes</p>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="text-xl font-bold text-gray-800 mb-4">Panel de Control</h3>
        <p class="text-gray-600 mb-4">Acceso a todas las funcionalidades del sistema</p>
        <div class="space-y-2">
            <a href="/Shipments" class="block text-indigo-600 hover:underline">📦 Gestionar Envíos</a>
            <a href="/Drivers" class="block text-indigo-600 hover:underline">🚗 Gestionar Conductores</a>
            <a href="/Admin" class="block text-indigo-600 hover:underline">⚙️ Configuración</a>
        </div>
    </div>
}
else if (userRole == "Client")
{
    <!-- CLIENT DASHBOARD -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-indigo-600">
            <h3 class="text-gray-600 text-sm font-bold">Mis Envíos</h3>
            <p class="text-4xl font-bold text-indigo-600">@ViewBag.MyShipments</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-green-600">
            <h3 class="text-gray-600 text-sm font-bold">Entregados</h3>
            <p class="text-4xl font-bold text-green-600">@ViewBag.DeliveredShipments</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-red-600">
            <h3 class="text-gray-600 text-sm font-bold">Pendientes</h3>
            <p class="text-4xl font-bold text-red-600">@ViewBag.PendingShipments</p>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="text-xl font-bold text-gray-800 mb-4">Acciones</h3>
        <a href="/Shipments/Create" class="bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 inline-block">
            + Crear Nuevo Envío
        </a>
    </div>
}
else if (userRole == "Driver")
{
    <!-- DRIVER DASHBOARD -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-indigo-600">
            <h3 class="text-gray-600 text-sm font-bold">Total Entregas</h3>
            <p class="text-4xl font-bold text-indigo-600">@ViewBag.TotalDeliveries</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-yellow-600">
            <h3 class="text-gray-600 text-sm font-bold">Calificación</h3>
            <p class="text-4xl font-bold text-yellow-600">⭐ @ViewBag.Rating</p>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="text-xl font-bold text-gray-800 mb-4">Mi Información</h3>
        <p class="text-gray-600">Perfil y estadísticas de desempeño</p>
    </div>
}
else
{
    <!-- DEFAULT DASHBOARD -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-indigo-600">
            <h3 class="text-gray-600 text-sm font-bold">Total Envíos</h3>
            <p class="text-4xl font-bold text-indigo-600">1,234</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-green-600">
            <h3 class="text-gray-600 text-sm font-bold">Entregados</h3>
            <p class="text-4xl font-bold text-green-600">856</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-yellow-600">
            <h3 class="text-gray-600 text-sm font-bold">En Tránsito</h3>
            <p class="text-4xl font-bold text-yellow-600">245</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-red-600">
            <h3 class="text-gray-600 text-sm font-bold">Pendientes</h3>
            <p class="text-4xl font-bold text-red-600">133</p>
        </div>
    </div>
}
