@model LogisticaApp.Models.Driver

@{
    ViewData["Title"] = "Eliminar Conductor";
}

<h2 class="text-2xl font-bold mb-4 text-red-600">🗑️ Eliminar Conductor</h2>

<div class="bg-white p-6 rounded-lg shadow-md max-w-2xl mb-4">
    <p class="text-gray-700 mb-4">¿Está seguro que desea eliminar al conductor <strong>@Model.User?.Name</strong>?</p>
    
    <dl class="mb-6 border-l-4 border-red-600 pl-4">
        <dt class="font-bold">Licencia:</dt>
        <dd class="text-gray-700">@Model.LicenseNumber</dd>
        
        <dt class="font-bold mt-2">Entregas Realizadas:</dt>
        <dd class="text-gray-700">@Model.TotalDeliveries</dd>
        
        <dt class="font-bold mt-2">Calificación:</dt>
        <dd class="text-gray-700">⭐ @Model.AverageRating.ToString("F1")</dd>
        
        <dt class="font-bold mt-2">Estado:</dt>
        <dd class="text-gray-700">@Model.Status</dd>
    </dl>

    <form method="post" style="display:inline;">
        <button type="submit" class="bg-red-600 text-white px-6 py-2 rounded hover:bg-red-700 font-bold">Confirmar Eliminación</button>
    </form>
    <a href="/Drivers" class="bg-gray-400 text-white px-6 py-2 rounded hover:bg-gray-500 font-bold inline-block">Cancelar</a>
</div>
