@model LogisticaApp.Models.Driver

@{
    ViewData["Title"] = "Crear Conductor";
}

<h2 class="text-3xl font-bold text-gray-800 mb-8">Nuevo Conductor</h2>

<div class="bg-white rounded-lg shadow-md p-8 max-w-2xl">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-6">
            @Html.ValidationSummary(false)
        </div>
    }

    <form method="post" action="/Drivers/Create" class="space-y-6">
        <div>
            <label class="block text-gray-700 font-bold mb-2">Usuario (Conductor) *</label>
            <select name="UserId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600" required>
                <option value="">Seleccionar conductor...</option>
                @foreach (var user in (List<LogisticaApp.Models.User>)ViewBag.Users)
                {
                    <option value="@user.Id">@user.Name (@user.Email)</option>
                }
            </select>
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-2">Número de Licencia *</label>
            <input type="text" name="LicenseNumber" 
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600"
                placeholder="AB123456" required>
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-2">Vencimiento de Licencia *</label>
            <input type="date" name="LicenseExpiry" 
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600" required>
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-2">Vehículo</label>
            <select name="VehicleId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600">
                <option value="">Sin asignar</option>
                @foreach (var vehicle in (List<LogisticaApp.Models.Vehicle>)ViewBag.Vehicles)
                {
                    <option value="@vehicle.Id">@vehicle.LicensePlate - @vehicle.Brand @vehicle.Model</option>
                }
            </select>
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-2">Estado *</label>
            <select name="Status" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600">
                <option value="Available">Disponible</option>
                <option value="OnDelivery">En Entrega</option>
                <option value="OnBreak">En Descanso</option>
                <option value="Inactive">Inactivo</option>
            </select>
        </div>

        <div class="flex gap-4 pt-4">
            <button type="submit" class="bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 font-bold">
                Crear Conductor
            </button>
            <a href="/Drivers" class="bg-gray-300 text-gray-700 px-6 py-2 rounded-lg hover:bg-gray-400 font-bold">
                Cancelar
            </a>
        </div>
    </form>
</div>
