@model List<LogisticaApp.Services.DriverWorkload>

@{
    ViewData["Title"] = "Carga de Conductores";
}

<h2 class="text-3xl font-bold text-gray-800 mb-8">👥 Carga de Conductores</h2>

<div class="bg-white rounded-lg shadow-md p-6">
    @if (Model.Count == 0)
    {
        <p class="text-gray-500 text-center py-8">No hay conductores registrados</p>
    }
    else
    {
        <table class="w-full">
            <thead class="border-b bg-gray-50">
                <tr>
                    <th class="text-left py-3 px-4">Conductor</th>
                    <th class="text-left py-3 px-4">Entregas Activas</th>
                    <th class="text-left py-3 px-4">Rating</th>
                    <th class="text-left py-3 px-4">Estado</th>
                    <th class="text-left py-3 px-4">Capacidad</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var driver in Model)
                {
                    var capacityColor = driver.ActiveDeliveries switch
                    {
                        0 => "bg-green-100 text-green-700",
                        1 or 2 => "bg-yellow-100 text-yellow-700",
                        _ => "bg-red-100 text-red-700"
                    };
                    
                    var capacityText = driver.ActiveDeliveries switch
                    {
                        0 => "Disponible",
                        1 or 2 => "Parcial",
                        _ => "Ocupado"
                    };
                    
                    <tr class="border-b hover:bg-gray-50">
                        <td class="py-3 px-4 font-bold">@driver.DriverName</td>
                        <td class="py-3 px-4">@driver.ActiveDeliveries entregas</td>
                        <td class="py-3 px-4">
                            <div class="flex items-center gap-2">
                                <span class="text-yellow-500">⭐</span>
                                @Math.Round(driver.Rating, 2)
                            </div>
                        </td>
                        <td class="py-3 px-4">@driver.Status</td>
                        <td class="py-3 px-4">
                            <span class="px-3 py-1 rounded-full text-sm font-bold @capacityColor">
                                @capacityText
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div class="mt-8">
    <a href="/Shipments/Index" class="bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 font-bold">
        ← Volver a Envíos
    </a>
</div>
