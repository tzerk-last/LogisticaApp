@model LogisticaApp.Models.Shipment

@{
    ViewData["Title"] = "Crear Envío";
}

<h2 class="text-3xl font-bold text-gray-800 mb-8">Nuevo Envío</h2>

<div class="bg-white rounded-lg shadow-md p-8 max-w-2xl">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-6">
            @Html.ValidationSummary(false)
        </div>
    }

    <form method="post" action="/Shipments/Create" class="space-y-6">
        <div>
            <label class="block text-gray-700 font-bold mb-2">Número de Guía *</label>
            <input type="text" name="GuideNumber" 
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600"
                placeholder="GU-001" required>
            @Html.ValidationMessageFor(m => m.GuideNumber, "", new { @class = "text-red-500 text-sm mt-1" })
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-gray-700 font-bold mb-2">Cliente *</label>
                <select name="ClientId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600" required>
                    <option value="">Seleccionar cliente...</option>
                    @foreach (var client in (List<LogisticaApp.Models.User>)ViewBag.Clients)
                    {
                        <option value="@client.Id">@client.Name</option>
                    }
                </select>
                @Html.ValidationMessageFor(m => m.ClientId, "", new { @class = "text-red-500 text-sm mt-1" })
            </div>

            <div>
                <label class="block text-gray-700 font-bold mb-2">Ruta *</label>
                <select name="RouteId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600" required>
                    <option value="">Seleccionar ruta...</option>
                    @foreach (var route in (List<LogisticaApp.Models.Route>)ViewBag.Routes)
                    {
                        <option value="@route.Id">@route.OriginAddress → @route.DestinationAddress</option>
                    }
                </select>
                @Html.ValidationMessageFor(m => m.RouteId, "", new { @class = "text-red-500 text-sm mt-1" })
            </div>
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-2">Tipo de Carga *</label>
            <input type="text" name="CargoType" 
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600"
                placeholder="Electrónica, Ropa, etc." required>
            @Html.ValidationMessageFor(m => m.CargoType, "", new { @class = "text-red-500 text-sm mt-1" })
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-gray-700 font-bold mb-2">Peso (kg) *</label>
                <input type="number" step="0.01" name="Weight" 
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600"
                    placeholder="0.00" required>
                @Html.ValidationMessageFor(m => m.Weight, "", new { @class = "text-red-500 text-sm mt-1" })
            </div>

            <div>
                <label class="block text-gray-700 font-bold mb-2">Precio Base ($) *</label>
                <input type="number" step="0.01" name="BasePrice" 
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600"
                    placeholder="0.00" required>
                @Html.ValidationMessageFor(m => m.BasePrice, "", new { @class = "text-red-500 text-sm mt-1" })
            </div>
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-2">Descripción</label>
            <textarea name="Description" 
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600"
                rows="4" placeholder="Detalles del envío..."></textarea>
            @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-red-500 text-sm mt-1" })
        </div>

        <div class="flex gap-4 pt-4">
            <button type="submit" class="bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 font-bold">
                Crear Envío
            </button>
            <a href="/Shipments" class="bg-gray-300 text-gray-700 px-6 py-2 rounded-lg hover:bg-gray-400 font-bold">
                Cancelar
            </a>
        </div>
    </form>
</div>
