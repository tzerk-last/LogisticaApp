@model LogisticaApp.Models.Shipment

@{
    ViewData["Title"] = "Editar Envío";
}

<h2 class="text-2xl font-bold mb-4">✏️ Editar Envío</h2>

<form method="post" class="bg-white p-6 rounded-lg shadow-md">
    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
            <label class="block font-bold mb-2">Número de Guía</label>
            <input type="text" name="GuideNumber" value="@Model.GuideNumber" class="w-full border rounded px-3 py-2" required />
        </div>
        <div>
            <label class="block font-bold mb-2">Cliente</label>
            <select name="ClientId" class="w-full border rounded px-3 py-2" required></select>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
            <label class="block font-bold mb-2">Tipo de Carga</label>
            <input type="text" name="CargoType" value="@Model.CargoType" class="w-full border rounded px-3 py-2" required />
        </div>
        <div>
            <label class="block font-bold mb-2">Peso (kg)</label>
            <input type="number" name="Weight" step="0.01" value="@Model.Weight" class="w-full border rounded px-3 py-2" required />
        </div>
    </div>

    <div class="mb-4">
        <label class="block font-bold mb-2">Descripción</label>
        <textarea name="Description" class="w-full border rounded px-3 py-2" rows="4" required>@Model.Description</textarea>
    </div>

    <div class="flex gap-2">
        <button type="submit" class="bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700">Guardar</button>
        <a href="/Shipments" class="bg-gray-400 text-white px-4 py-2 rounded hover:bg-gray-500">Cancelar</a>
    </div>
</form>
