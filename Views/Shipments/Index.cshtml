@model List<LogisticaApp.Models.Shipment>

@{
    ViewData["Title"] = "Envíos";
}

<div class="flex justify-between items-center mb-8">
    <h2 class="text-3xl font-bold text-gray-800">📦 Envíos</h2>
    <div class="flex gap-4">
        <a href="/Shipments/Create" class="bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 font-bold">
            ➕ Nuevo Envío
        </a>
        <a href="/Shipments/DriverWorkload" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 font-bold">
            👥 Carga de Conductores
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="bg-green-100 text-green-700 px-4 py-3 rounded-lg mb-4">
        ✅ @TempData["SuccessMessage"]
    </div>
}

<div class="bg-white rounded-lg shadow-md p-6">
    @if (Model.Count == 0)
    {
        <p class="text-gray-500 text-center py-8">No hay envíos</p>
    }
    else
    {
        <table class="w-full">
            <thead class="border-b bg-gray-50">
                <tr>
                    <th class="text-left py-3 px-4">Guía</th>
                    <th class="text-left py-3 px-4">Cliente</th>
                    <th class="text-left py-3 px-4">Conductor</th>
                    <th class="text-left py-3 px-4">Estado</th>
                    <th class="text-left py-3 px-4">Monto</th>
                    <th class="text-left py-3 px-4">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var shipment in Model)
                {
                    var statusColor = shipment.Status switch
                    {
                        ShipmentStatus.Delivered => "bg-green-100 text-green-700",
                        ShipmentStatus.Assigned => "bg-blue-100 text-blue-700",
                        ShipmentStatus.Cancelled => "bg-red-100 text-red-700",
                        _ => "bg-yellow-100 text-yellow-700"
                    };
                    
                    <tr class="border-b hover:bg-gray-50">
                        <td class="py-3 px-4 font-bold">@shipment.GuideNumber</td>
                        <td class="py-3 px-4">@shipment.Client?.Name</td>
                        <td class="py-3 px-4">@(shipment.Driver?.User?.Name ?? "Sin asignar")</td>
                        <td class="py-3 px-4">
                            <span class="px-3 py-1 rounded-full text-sm font-bold @statusColor">
                                @shipment.Status
                            </span>
                        </td>
                        <td class="py-3 px-4">${@Math.Round(shipment.TotalCost, 2)}</td>
                        <td class="py-3 px-4 text-sm">
                            @if (shipment.Status != ShipmentStatus.Assigned && shipment.Status != ShipmentStatus.Delivered)
                            {
                                <form method="post" action="/Shipments/AssignSmartly/@shipment.Id" style="display:inline;">
                                    <button type="submit" class="bg-indigo-600 text-white px-3 py-1 rounded hover:bg-indigo-700 text-xs font-bold">
                                        🤖 Asignar
                                    </button>
                                </form>
                            }
                            <a href="/Shipments/Edit/@shipment.Id" class="text-indigo-600 hover:underline ml-2">Editar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
