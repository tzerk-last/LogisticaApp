@model List<LogisticaApp.Models.Shipment>

@{
    ViewData["Title"] = "Envíos";
}

<div class="flex justify-between items-center mb-8">
    <h2 class="text-3xl font-bold text-gray-800">Lista de Envíos</h2>
    <a href="/Shipments/Create" class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 font-bold">
        + Nuevo Envío
    </a>
</div>

<div class="bg-white rounded-lg shadow-md p-6">
    @if (Model.Count == 0)
    {
        <div class="text-center text-gray-500 py-8">
            <p class="text-lg">No hay envíos registrados</p>
        </div>
    }
    else
    {
        <table class="w-full">
            <thead class="border-b bg-gray-50">
                <tr>
                    <th class="text-left py-3 px-4">Guía</th>
                    <th class="text-left py-3 px-4">Cliente</th>
                    <th class="text-left py-3 px-4">Tipo</th>
                    <th class="text-left py-3 px-4">Peso</th>
                    <th class="text-left py-3 px-4">Precio</th>
                    <th class="text-left py-3 px-4">Estado</th>
                    <th class="text-left py-3 px-4">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var shipment in Model)
                {
                    <tr class="border-b hover:bg-gray-50">
                        <td class="py-3 px-4 font-bold">@shipment.GuideNumber</td>
                        <td class="py-3 px-4">@shipment.Client?.Name</td>
                        <td class="py-3 px-4">@shipment.CargoType</td>
                        <td class="py-3 px-4">@shipment.Weight kg</td>
                        <td class="py-3 px-4">${{ shipment.BasePrice }}</td>
                        <td class="py-3 px-4">
                            <span class="px-3 py-1 rounded-full text-sm font-bold
                                @(shipment.Status == LogisticaApp.Models.ShipmentStatus.Delivered ? "bg-green-100 text-green-700" :
                                  shipment.Status == LogisticaApp.Models.ShipmentStatus.InTransit ? "bg-yellow-100 text-yellow-700" :
                                  shipment.Status == LogisticaApp.Models.ShipmentStatus.Cancelled ? "bg-red-100 text-red-700" :
                                  "bg-blue-100 text-blue-700")">
                                @shipment.Status
                            </span>
                        </td>
                        <td class="py-3 px-4 space-x-2">
                            <a href="/Shipments/Edit/@shipment.Id" class="text-indigo-600 hover:underline text-sm">
                                ✏️ Editar
                            </a>
                            <a href="/Shipments/Delete/@shipment.Id" class="text-red-600 hover:underline text-sm">
                                🗑️ Eliminar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
