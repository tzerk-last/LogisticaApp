@using LogisticaApp.Models
@model LogisticaApp.Models.Incident

@{
    ViewData["Title"] = "Detalles de Incidencia";
}

<div class="mb-8">
    <a href="/Incidents" class="text-indigo-600 hover:underline">← Volver a Incidencias</a>
</div>

<div class="bg-white rounded-lg shadow-md p-6 max-w-3xl">
    <h2 class="text-2xl font-bold mb-6 text-red-600">⚠️ @Model.IncidentType</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div>
            <h3 class="font-bold text-lg mb-3">Información del Envío</h3>
            <dl class="space-y-2">
                <div>
                    <dt class="font-semibold">Guía:</dt>
                    <dd>@Model.Shipment?.GuideNumber</dd>
                </div>
                <div>
                    <dt class="font-semibold">Cliente:</dt>
                    <dd>@Model.Shipment?.Client?.Name</dd>
                </div>
                <div>
                    <dt class="font-semibold">Costo:</dt>
                    <dd>${@Model.Shipment?.TotalCost.ToString("F2")}</dd>
                </div>
            </dl>
        </div>

        <div>
            <h3 class="font-bold text-lg mb-3">Información del Conductor</h3>
            <dl class="space-y-2">
                <div>
                    <dt class="font-semibold">Nombre:</dt>
                    <dd>@Model.Driver?.User?.Name</dd>
                </div>
                <div>
                    <dt class="font-semibold">Licencia:</dt>
                    <dd>@Model.Driver?.LicenseNumber</dd>
                </div>
                <div>
                    <dt class="font-semibold">Calificación:</dt>
                    <dd>⭐ @Model.Driver?.AverageRating.ToString("F1")</dd>
                </div>
            </dl>
        </div>
    </div>

    <div class="border-t pt-6 mb-6">
        <h3 class="font-bold text-lg mb-3">Detalles de la Incidencia</h3>
        <dl class="space-y-3">
            <div>
                <dt class="font-semibold">Fecha Reportada:</dt>
                <dd>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</dd>
            </div>
            <div>
                <dt class="font-semibold">Estado:</dt>
                <dd>
                    <span class="@(Model.Status.ToString() == "Reported" ? "bg-red-100 text-red-700" : Model.Status.ToString() == "Investigating" ? "bg-yellow-100 text-yellow-700" : Model.Status.ToString() == "Resolved" ? "bg-blue-100 text-blue-700" : "bg-green-100 text-green-700") px-3 py-1 rounded-full font-bold">
                        @Model.Status
                    </span>
                </dd>
            </div>
            <div>
                <dt class="font-semibold">Descripción:</dt>
                <dd class="bg-gray-50 p-3 rounded">@Model.Description</dd>
            </div>
            @if (!string.IsNullOrEmpty(Model.ResolutionNotes))
            {
                <div>
                    <dt class="font-semibold">Notas de Resolución:</dt>
                    <dd class="bg-green-50 p-3 rounded">@Model.ResolutionNotes</dd>
                </div>
            }
            @if (Model.ResolvedAt.HasValue)
            {
                <div>
                    <dt class="font-semibold">Fecha de Resolución:</dt>
                    <dd>@Model.ResolvedAt?.ToString("dd/MM/yyyy HH:mm:ss")</dd>
                </div>
            }
        </dl>
    </div>

    @if (!string.IsNullOrEmpty(Model.PhotoPath))
    {
        <div class="border-t pt-6 mb-6">
            <h3 class="font-bold text-lg mb-3">Evidencia Fotográfica</h3>
            <img src="@Model.PhotoPath" alt="Foto de evidencia" class="max-w-md rounded-lg shadow" />
        </div>
    }

    <div class="flex gap-2 border-t pt-6">
        <a href="/Incidents/Edit/@Model.Id" class="bg-indigo-600 text-white px-6 py-2 rounded hover:bg-indigo-700 font-bold">Editar</a>
        <a href="/Incidents" class="bg-gray-400 text-white px-6 py-2 rounded hover:bg-gray-500 font-bold">Volver</a>
    </div>
</div>
