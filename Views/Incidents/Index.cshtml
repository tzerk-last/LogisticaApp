@using LogisticaApp.Models
@model List<LogisticaApp.Models.Incident>

@{
    ViewData["Title"] = "Incidencias";
}

<div class="flex justify-between items-center mb-8">
    <h2 class="text-3xl font-bold text-gray-800">⚠️ Incidencias</h2>
    <a href="/Incidents/Create" class="bg-red-600 text-white px-6 py-2 rounded-lg hover:bg-red-700 font-bold">
        ➕ Reportar Incidencia
    </a>
</div>

<div class="bg-white rounded-lg shadow-md p-6">
    @if (Model.Count == 0)
    {
        <p class="text-gray-500 text-center py-8">No hay incidencias registradas</p>
    }
    else
    {
        <table class="w-full">
            <thead class="border-b bg-gray-50">
                <tr>
                    <th class="text-left py-3 px-4">Tipo</th>
                    <th class="text-left py-3 px-4">Guía de Envío</th>
                    <th class="text-left py-3 px-4">Conductor</th>
                    <th class="text-left py-3 px-4">Fecha</th>
                    <th class="text-left py-3 px-4">Estado</th>
                    <th class="text-left py-3 px-4">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var incident in Model)
                {
                    var statusColor = incident.Status switch
                    {
                        IncidentStatus.Reported => "bg-red-100 text-red-700",
                        IncidentStatus.Investigating => "bg-yellow-100 text-yellow-700",
                        IncidentStatus.Resolved => "bg-blue-100 text-blue-700",
                        _ => "bg-green-100 text-green-700"
                    };
                    
                    <tr class="border-b hover:bg-gray-50">
                        <td class="py-3 px-4 font-bold">@incident.IncidentType</td>
                        <td class="py-3 px-4">@incident.Shipment?.GuideNumber</td>
                        <td class="py-3 px-4">@incident.Driver?.User?.Name</td>
                        <td class="py-3 px-4">@incident.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="py-3 px-4">
                            <span class="px-3 py-1 rounded-full text-sm font-bold @statusColor">
                                @incident.Status
                            </span>
                        </td>
                        <td class="py-3 px-4 text-sm">
                            <a href="/Incidents/Details/@incident.Id" class="text-indigo-600 hover:underline">Ver</a>
                            <a href="/Incidents/Edit/@incident.Id" class="text-indigo-600 hover:underline ml-2">Editar</a>
                            <a href="/Incidents/Delete/@incident.Id" class="text-red-600 hover:underline ml-2">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
