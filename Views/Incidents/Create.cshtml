@model LogisticaApp.Models.Incident

@{
    ViewData["Title"] = "Reportar Incidencia";
}

<h2 class="text-3xl font-bold text-gray-800 mb-8">⚠️ Reportar Incidencia</h2>

<div class="bg-white rounded-lg shadow-md p-6 max-w-2xl">
    <form method="post" enctype="multipart/form-data">
        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Envío (Guía)</label>
            <input type="number" name="shipmentId" value="@ViewBag.ShipmentId" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
            @if (ViewBag.GuideNumber != null)
            {
                <p class="text-sm text-gray-600 mt-2">📦 @ViewBag.GuideNumber</p>
            }
        </div>

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Tipo de Incidencia</label>
            <select name="incidentType" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                <option value="">Seleccionar...</option>
                <option value="Delay">Retraso en entrega</option>
                <option value="Damage">Daño en producto</option>
                <option value="Wrong">Entrega incorrecta</option>
                <option value="Missing">Artículo faltante</option>
                <option value="Other">Otro</option>
            </select>
        </div>

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Descripción</label>
            <textarea name="description" rows="5" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required></textarea>
        </div>

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Foto de Evidencia</label>
            <input type="file" name="photoFile" accept="image/*" class="w-full px-4 py-2 border border-gray-300 rounded-lg">
        </div>

        <div class="flex gap-4">
            <button type="submit" class="bg-red-600 text-white px-6 py-2 rounded-lg hover:bg-red-700 font-bold">
                📤 Reportar Incidencia
            </button>
            <a href="/Incidents/Index" class="bg-gray-500 text-white px-6 py-2 rounded-lg hover:bg-gray-600 font-bold">
                Cancelar
            </a>
        </div>
    </form>
</div>
