@model LogisticaApp.Models.Incident

@{
    ViewData["Title"] = "Reportar Incidencia";
}

<h2 class="text-2xl font-bold mb-4">⚠️ Reportar Nueva Incidencia</h2>

<form method="post" enctype="multipart/form-data" class="bg-white p-6 rounded-lg shadow-md max-w-2xl">
    <div class="mb-4">
        <label class="block font-bold mb-2">ID del Envío</label>
        <input type="number" name="ShipmentId" value="@ViewBag.ShipmentId" class="w-full border rounded px-3 py-2" required />
        @if (ViewBag.GuideNumber != null)
        {
            <p class="text-gray-600 text-sm mt-1">Guía: @ViewBag.GuideNumber</p>
        }
    </div>

    <div class="mb-4">
        <label class="block font-bold mb-2">ID del Conductor</label>
        <input type="number" name="DriverId" value="@ViewBag.DriverId" class="w-full border rounded px-3 py-2" required />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
            <label class="block font-bold mb-2">Tipo de Incidencia</label>
            <input type="text" name="IncidentType" placeholder="ej: Retraso, Daño, Pérdida" class="w-full border rounded px-3 py-2" required />
        </div>
    </div>

    <div class="mb-4">
        <label class="block font-bold mb-2">Descripción</label>
        <textarea name="Description" class="w-full border rounded px-3 py-2" rows="4" placeholder="Describe el incidente en detalle..." required></textarea>
    </div>

    <div class="mb-4">
        <label class="block font-bold mb-2">Foto de Evidencia (Opcional)</label>
        <input type="file" name="photoFile" accept="image/*" class="w-full border rounded px-3 py-2" />
        <p class="text-gray-600 text-sm mt-1">Formatos permitidos: JPG, PNG</p>
    </div>

    <div class="flex gap-2">
        <button type="submit" class="bg-red-600 text-white px-6 py-2 rounded hover:bg-red-700 font-bold">Reportar Incidencia</button>
        <a href="/Incidents" class="bg-gray-400 text-white px-6 py-2 rounded hover:bg-gray-500 font-bold">Cancelar</a>
    </div>
</form>
