<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - LogisticaApp</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
    <!-- Navbar -->
    <nav class="bg-white shadow-md">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <a href="/Home/Dashboard" class="text-2xl font-bold text-indigo-600">LogisticaApp</a>
            <div class="flex items-center gap-4">
                <span class="text-gray-700">@Context.Session.GetString("UserEmail")</span>
                <span class="bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full text-sm">
                    @Context.Session.GetString("UserRole")
                </span>
                <a href="/Home/Logout" class="bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700">
                    Logout
                </a>
            </div>
        </div>
    </nav>

    <div class="flex">
        <!-- Sidebar Dinámico -->
        <aside class="w-64 bg-white shadow-md min-h-screen p-6">
            @{
                var userRole = Context.Session.GetString("UserRole");
            }

            <ul class="space-y-4">
                <li>
                    <a href="/Home/Dashboard" class="block text-indigo-600 font-bold px-4 py-2 rounded-lg hover:bg-indigo-50">
                        📊 Dashboard
                    </a>
                </li>

                @if (userRole == "Admin")
                {
                    <li>
                        <a href="/Shipments" class="block text-gray-700 hover:text-indigo-600 px-4 py-2 rounded-lg hover:bg-gray-50">
                            📦 Envíos
                        </a>
                    </li>
                    <li>
                        <a href="/Drivers" class="block text-gray-700 hover:text-indigo-600 px-4 py-2 rounded-lg hover:bg-gray-50">
                            🚗 Conductores
                        </a>
                    </li>
                    <li>
                        <a href="/Vehicles" class="block text-gray-700 hover:text-indigo-600 px-4 py-2 rounded-lg hover:bg-gray-50">
                            🚙 Vehículos
                        </a>
                    </li>
                    <li>
                        <a href="/Admin" class="block text-gray-700 hover:text-indigo-600 px-4 py-2 rounded-lg hover:bg-gray-50">
                            ⚙️ Administración
                        </a>
                    </li>
                }
                else if (userRole == "Operator")
                {
                    <li>
                        <a href="/Shipments" class="block text-gray-700 hover:text-indigo-600 px-4 py-2 rounded-lg hover:bg-gray-50">
                            📦 Envíos
                        </a>
                    </li>
                    <li>
                        <a href="/Drivers" class="block text-gray-700 hover:text-indigo-600 px-4 py-2 rounded-lg hover:bg-gray-50">
                            🚗 Conductores
                        </a>
                    </li>
                    <li>
                        <a href="/Vehicles" class="block text-gray-700 hover:text-indigo-600 px-4 py-2 rounded-lg hover:bg-gray-50">
                            🚙 Vehículos
                        </a>
                    </li>
                }
                else if (userRole == "Client")
                {
                    <li>
                        <a href="/Shipments" class="block text-gray-700 hover:text-indigo-600 px-4 py-2 rounded-lg hover:bg-gray-50">
                            📦 Mis Envíos
                        </a>
                    </li>
                    <li>
                        <a href="/Shipments/Create" class="block text-gray-700 hover:text-indigo-600 px-4 py-2 rounded-lg hover:bg-gray-50">
                            ➕ Crear Envío
                        </a>
                    </li>
                }
                else if (userRole == "Driver")
                {
                    <li>
                        <a href="/Shipments" class="block text-gray-700 hover:text-indigo-600 px-4 py-2 rounded-lg hover:bg-gray-50">
                            📦 Entregas Asignadas
                        </a>
                    </li>
                }
            </ul>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            @RenderBody()
        </main>
    </div>
</body>
</html>
