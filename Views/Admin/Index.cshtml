@model LogisticaApp.Services.FinancialSummary

@{
    ViewData["Title"] = "Dashboard Financiero";
}

<h2 class="text-3xl font-bold text-gray-800 mb-8">📊 Dashboard Financiero</h2>

<!-- Filtros -->
<div class="bg-white rounded-lg shadow-md p-6 mb-8">
    <form method="post" class="flex gap-4 items-end">
        <div>
            <label class="block text-gray-700 font-bold mb-2">Desde</label>
            <input type="date" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" class="px-4 py-2 border border-gray-300 rounded-lg">
        </div>
        <div>
            <label class="block text-gray-700 font-bold mb-2">Hasta</label>
            <input type="date" name="endDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" class="px-4 py-2 border border-gray-300 rounded-lg">
        </div>
        <button type="submit" class="bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 font-bold">
            Filtrar
        </button>
        <a href="/Admin/ExportToExcel?startDate=@Model.StartDate.ToString("yyyy-MM-dd")&endDate=@Model.EndDate.ToString("yyyy-MM-dd")" 
            class="bg-green-600 text-white px-6 py-2 rounded-lg hover:bg-green-700 font-bold">
            📥 Exportar Excel
        </a>
    </form>
</div>

<!-- Métricas Principales -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-green-600">
        <h3 class="text-gray-600 text-sm font-bold">Ingresos Totales</h3>
        <p class="text-4xl font-bold text-green-600">${@Math.Round(Model.TotalRevenue, 2)}</p>
        <p class="text-sm text-gray-500 mt-2">@Model.TotalShipments envíos</p>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-red-600">
        <h3 class="text-gray-600 text-sm font-bold">Costos Operativos</h3>
        <p class="text-4xl font-bold text-red-600">${@Math.Round(Model.OperatingCosts, 2)}</p>
        <p class="text-sm text-gray-500 mt-2">30% de ingresos</p>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6 border-l-4 border-indigo-600">
        <h3 class="text-gray-600 text-sm font-bold">Ganancia Neta</h3>
        <p class="text-4xl font-bold text-indigo-600">${@Math.Round(Model.Profit, 2)}</p>
        <p class="text-sm text-gray-500 mt-2">@Math.Round(Model.ProfitMargin, 2)% margen</p>
    </div>
</div>

<!-- Ingresos por Ruta -->
<div class="bg-white rounded-lg shadow-md p-6 mb-8">
    <h3 class="text-xl font-bold text-gray-800 mb-4">💰 Ingresos por Ruta</h3>
    <table class="w-full">
        <thead class="border-b bg-gray-50">
            <tr>
                <th class="text-left py-3 px-4">Ruta</th>
                <th class="text-left py-3 px-4">Ingresos</th>
                <th class="text-left py-3 px-4">Envíos</th>
                <th class="text-left py-3 px-4">Promedio</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var route in Model.RevenueByRoute.Take(10))
            {
                <tr class="border-b hover:bg-gray-50">
                    <td class="py-3 px-4 font-bold">@route.RouteName</td>
                    <td class="py-3 px-4">${@Math.Round(route.Revenue, 2)}</td>
                    <td class="py-3 px-4">@route.ShipmentCount</td>
                    <td class="py-3 px-4">${@Math.Round(route.Revenue / route.ShipmentCount, 2)}</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Ingresos por Cliente -->
<div class="bg-white rounded-lg shadow-md p-6">
    <h3 class="text-xl font-bold text-gray-800 mb-4">👥 Top Clientes</h3>
    <table class="w-full">
        <thead class="border-b bg-gray-50">
            <tr>
                <th class="text-left py-3 px-4">Cliente</th>
                <th class="text-left py-3 px-4">Ingresos</th>
                <th class="text-left py-3 px-4">Envíos</th>
                <th class="text-left py-3 px-4">Promedio</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in Model.RevenueByClient.Take(10))
            {
                <tr class="border-b hover:bg-gray-50">
                    <td class="py-3 px-4 font-bold">@client.ClientName</td>
                    <td class="py-3 px-4">${@Math.Round(client.Revenue, 2)}</td>
                    <td class="py-3 px-4">@client.ShipmentCount</td>
                    <td class="py-3 px-4">${@Math.Round(client.Revenue / client.ShipmentCount, 2)}</td>
                </tr>
            }
        </tbody>
    </table>
</div>
