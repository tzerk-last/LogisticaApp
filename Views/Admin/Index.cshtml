@using LogisticaApp.Services
@model dynamic

@{
    ViewData["Title"] = "Dashboard Administrativo";
}

<div class="mb-8">
    <h2 class="text-3xl font-bold text-gray-800">📊 Dashboard Administrativo</h2>
    <p class="text-gray-600 mt-2">Análisis financiero y operacional del sistema</p>
</div>

<!-- KPIs Principales -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-gradient-to-br from-blue-500 to-blue-600 text-white p-6 rounded-lg shadow-lg">
        <h3 class="text-sm font-semibold opacity-90">Ingresos Totales</h3>
        <p class="text-3xl font-bold mt-2">$@(Model.TotalRevenue?.ToString("F2") ?? "0.00")</p>
        <p class="text-xs mt-2 opacity-75">Este mes</p>
    </div>

    <div class="bg-gradient-to-br from-green-500 to-green-600 text-white p-6 rounded-lg shadow-lg">
        <h3 class="text-sm font-semibold opacity-90">Envíos Completados</h3>
        <p class="text-3xl font-bold mt-2">@(Model.CompletedShipments?.ToString() ?? "0")</p>
        <p class="text-xs mt-2 opacity-75">Este mes</p>
    </div>

    <div class="bg-gradient-to-br from-orange-500 to-orange-600 text-white p-6 rounded-lg shadow-lg">
        <h3 class="text-sm font-semibold opacity-90">Envíos Pendientes</h3>
        <p class="text-3xl font-bold mt-2">@(Model.PendingShipments?.ToString() ?? "0")</p>
        <p class="text-xs mt-2 opacity-75">En progreso</p>
    </div>

    <div class="bg-gradient-to-br from-purple-500 to-purple-600 text-white p-6 rounded-lg shadow-lg">
        <h3 class="text-sm font-semibold opacity-90">Conductores Activos</h3>
        <p class="text-3xl font-bold mt-2">@(Model.ActiveDrivers?.ToString() ?? "0")</p>
        <p class="text-xs mt-2 opacity-75">Disponibles</p>
    </div>
</div>

<!-- Tabla de Ingresos por Cliente -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
    <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="text-xl font-bold mb-4">💰 Ingresos por Cliente</h3>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="border-b bg-gray-50">
                    <tr>
                        <th class="text-left py-2 px-3">Cliente</th>
                        <th class="text-right py-2 px-3">Monto</th>
                        <th class="text-right py-2 px-3">%</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RevenueByClient != null && ((List<dynamic>)Model.RevenueByClient).Count > 0)
                    {
                        @foreach (var client in (List<dynamic>)Model.RevenueByClient)
                        {
                            <tr class="border-b hover:bg-gray-50">
                                <td class="py-2 px-3">@client.ClientName</td>
                                <td class="py-2 px-3 text-right font-bold">$@client.TotalRevenue?.ToString("F2")</td>
                                <td class="py-2 px-3 text-right">@client.Percentage?.ToString("F1")%</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="py-4 px-3 text-center text-gray-500">Sin datos disponibles</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="text-xl font-bold mb-4">📍 Ingresos por Ruta</h3>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="border-b bg-gray-50">
                    <tr>
                        <th class="text-left py-2 px-3">Ruta</th>
                        <th class="text-right py-2 px-3">Monto</th>
                        <th class="text-right py-2 px-3">%</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RevenueByRoute != null && ((List<dynamic>)Model.RevenueByRoute).Count > 0)
                    {
                        @foreach (var route in (List<dynamic>)Model.RevenueByRoute)
                        {
                            <tr class="border-b hover:bg-gray-50">
                                <td class="py-2 px-3">@route.RouteName</td>
                                <td class="py-2 px-3 text-right font-bold">$@route.TotalRevenue?.ToString("F2")</td>
                                <td class="py-2 px-3 text-right">@route.Percentage?.ToString("F1")%</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="py-4 px-3 text-center text-gray-500">Sin datos disponibles</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Botón Exportar a Excel -->
<div class="bg-white rounded-lg shadow-md p-6">
    <h3 class="text-xl font-bold mb-4">📥 Exportar Datos</h3>
    <p class="text-gray-600 mb-4">Descarga un reporte en Excel con todos los datos financieros</p>
    <a href="/Admin/ExportToExcel" class="bg-green-600 text-white px-6 py-2 rounded hover:bg-green-700 font-bold inline-block">
        📊 Descargar Excel
    </a>
</div>
