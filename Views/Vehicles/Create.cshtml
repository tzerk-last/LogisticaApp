@model LogisticaApp.Models.Vehicle

@{
    ViewData["Title"] = "Crear Vehículo";
}

<h2 class="text-3xl font-bold text-gray-800 mb-8">Nuevo Vehículo</h2>

<div class="bg-white rounded-lg shadow-md p-8 max-w-2xl">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-6">
            @Html.ValidationSummary(false)
        </div>
    }

    <form method="post" action="/Vehicles/Create" class="space-y-6">
        <div>
            <label class="block text-gray-700 font-bold mb-2">Placa *</label>
            <input type="text" name="LicensePlate" 
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600"
                placeholder="ABC-1234" required>
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-2">Marca *</label>
            <input type="text" name="Brand" 
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600"
                placeholder="Toyota" required>
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-2">Modelo *</label>
            <input type="text" name="Model" 
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600"
                placeholder="Hilux" required>
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-2">Año *</label>
            <input type="number" name="Year" 
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600"
                placeholder="2024" required>
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-2">Capacidad Máxima (kg) *</label>
            <input type="number" name="MaxWeightKg" step="0.01"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600"
                placeholder="5000" required>
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-2">Estado *</label>
            <select name="Status" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-600">
                <option value="Available">Disponible</option>
                <option value="InMaintenance">En Mantenimiento</option>
                <option value="Inactive">Inactivo</option>
            </select>
        </div>

        <div class="flex gap-4 pt-4">
            <button type="submit" class="bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 font-bold">
                Crear Vehículo
            </button>
            <a href="/Vehicles" class="bg-gray-300 text-gray-700 px-6 py-2 rounded-lg hover:bg-gray-400 font-bold">
                Cancelar
            </a>
        </div>
    </form>
</div>
