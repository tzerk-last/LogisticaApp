@model LogisticaApp.Models.Vehicle

@{
    ViewData["Title"] = "Editar Vehículo";
}

<h2 class="text-2xl font-bold mb-4">✏️ Editar Vehículo</h2>

<form method="post" class="bg-white p-6 rounded-lg shadow-md max-w-2xl">

    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">

        <div>
            <label class="block font-bold mb-2">Placa</label>
            <input type="text"
                   name="LicensePlate"
                   value="@Model.LicensePlate"
                   class="w-full border rounded px-3 py-2"
                   required />
        </div>

        <div>
            <label class="block font-bold mb-2">Marca</label>
            <input type="text"
                   name="Brand"
                   value="@Model.Brand"
                   class="w-full border rounded px-3 py-2"
                   required />
        </div>

    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">

        <div>
            <label class="block font-bold mb-2">Modelo</label>
            <input type="text"
                   name="Model"
                   value="@Model.Model"
                   class="w-full border rounded px-3 py-2"
                   required />
        </div>

        <div>
            <label class="block font-bold mb-2">Año</label>
            <input type="number"
                   name="Year"
                   value="@Model.Year"
                   min="2000"
                   max="2099"
                   class="w-full border rounded px-3 py-2"
                   required />
        </div>

    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">

        <div>
            <label class="block font-bold mb-2">
                Capacidad Máxima (kg)
            </label>

            <input type="number"
                   name="MaxWeightKg"
                   value="@Model.MaxWeightKg"
                   step="100"
                   class="w-full border rounded px-3 py-2"
                   required />
        </div>

        <div>
            <label class="block font-bold mb-2">Estado</label>

            <select name="Status"
                    class="w-full border rounded px-3 py-2">

                <option value="0">Disponible</option>
                <option value="1">En Mantenimiento</option>
                <option value="2">Inactivo</option>

            </select>

        </div>

    </div>

    <div class="flex gap-2">

        <button type="submit"
                class="bg-indigo-600 text-white px-6 py-2 rounded hover:bg-indigo-700 font-bold">
            Guardar Cambios
        </button>

        <a href="/Vehicles"
           class="bg-gray-400 text-white px-6 py-2 rounded hover:bg-gray-500 font-bold">
            Cancelar
        </a>

    </div>

</form>
