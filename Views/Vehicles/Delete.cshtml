@model LogisticaApp.Models.Vehicle

@{
    ViewData["Title"] = "Eliminar Vehículo";
}

<h2 class="text-2xl font-bold mb-4 text-red-600">
    🗑️ Eliminar Vehículo
</h2>

<div class="bg-white p-6 rounded-lg shadow-md max-w-2xl mb-4">

    <p class="text-gray-700 mb-4">
        ¿Está seguro que desea eliminar el vehículo
        <strong>
            @Model.Brand @Model.Model (@Model.LicensePlate)
        </strong>?
    </p>

    <dl class="mb-6 border-l-4 border-red-600 pl-4 space-y-2">

        <div>
            <dt class="font-bold">Placa:</dt>
            <dd>@Model.LicensePlate</dd>
        </div>

        <div>
            <dt class="font-bold">Marca / Modelo:</dt>
            <dd>@Model.Brand @Model.Model @Model.Year</dd>
        </div>

        <div>
            <dt class="font-bold">Capacidad:</dt>
            <dd>@Model.MaxWeightKg kg</dd>
        </div>

        <div>
            <dt class="font-bold">Estado:</dt>
            <dd>@Model.Status</dd>
        </div>

    </dl>

    <form method="post" style="display:inline;">
        <button type="submit"
                class="bg-red-600 text-white px-6 py-2 rounded hover:bg-red-700 font-bold">
            Confirmar Eliminación
        </button>
    </form>

    <a href="/Vehicles"
       class="bg-gray-400 text-white px-6 py-2 rounded hover:bg-gray-500 font-bold inline-block">
        Cancelar
    </a>

</div>
