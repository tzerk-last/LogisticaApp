@model List<LogisticaApp.Models.Tariff>

@{
    ViewData["Title"] = "Tarifas";
}

<div class="flex justify-between items-center mb-8">
    <h2 class="text-3xl font-bold text-gray-800">💰 Tarifas de Envío</h2>
    <a href="/Tariffs/Create" class="bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 font-bold">
        ➕ Nueva Tarifa
    </a>
</div>

<div class="bg-white rounded-lg shadow-md p-6">
    @if (Model.Count == 0)
    {
        <p class="text-gray-500 text-center py-8">No hay tarifas configuradas</p>
    }
    else
    {
        <table class="w-full">
            <thead class="border-b bg-gray-50">
                <tr>
                    <th class="text-left py-3 px-4">Nombre</th>
                    <th class="text-left py-3 px-4">Rango de Distancia</th>
                    <th class="text-left py-3 px-4">Precio Base</th>
                    <th class="text-left py-3 px-4">Por Kg</th>
                    <th class="text-left py-3 px-4">Prioridad</th>
                    <th class="text-left py-3 px-4">Estado</th>
                    <th class="text-left py-3 px-4">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tariff in Model)
                {
                    <tr class="border-b hover:bg-gray-50">
                        <td class="py-3 px-4 font-bold">@tariff.Name</td>
                        <td class="py-3 px-4">@tariff.MinDistance km - @tariff.MaxDistance km</td>
                        <td class="py-3 px-4 font-bold">${@tariff.BasePrice.ToString("F2")}</td>
                        <td class="py-3 px-4">${@tariff.PricePerKg.ToString("F2")}</td>
                        <td class="py-3 px-4">
                            @if (tariff.IsPriority)
                            {
                                <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs font-bold">⚡ URGENTE</span>
                            }
                            else
                            {
                                <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded text-xs">Normal</span>
                            }
                        </td>
                        <td class="py-3 px-4">
                            <span class="@(tariff.IsActive ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700") px-3 py-1 rounded-full text-sm font-bold">
                                @(tariff.IsActive ? "Activa" : "Inactiva")
                            </span>
                        </td>
                        <td class="py-3 px-4 text-sm">
                            <a href="/Tariffs/Edit/@tariff.Id" class="text-indigo-600 hover:underline">Editar</a>
                            <a href="/Tariffs/Delete/@tariff.Id" class="text-red-600 hover:underline ml-2">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
