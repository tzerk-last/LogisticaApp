@model LogisticaApp.Models.Tariff

@{
    ViewData["Title"] = "Eliminar Tarifa";
}

<h2 class="text-2xl font-bold mb-4 text-red-600">🗑️ Eliminar Tarifa</h2>

<div class="bg-white p-6 rounded-lg shadow-md max-w-2xl mb-4">
    <p class="text-gray-700 mb-4">¿Está seguro que desea eliminar la tarifa <strong>@Model.Name</strong>?</p>
    
    <dl class="mb-6 border-l-4 border-red-600 pl-4">
        <dt class="font-bold">Rango de Distancia:</dt>
        <dd class="text-gray-700">@Model.MinDistance km - @Model.MaxDistance km</dd>
        
        <dt class="font-bold mt-2">Precio Base:</dt>
        <dd class="text-gray-700">${@Model.BasePrice.ToString("F2")}</dd>
        
        <dt class="font-bold mt-2">Precio por Kg:</dt>
        <dd class="text-gray-700">${@Model.PricePerKg.ToString("F2")}</dd>
        
        <dt class="font-bold mt-2">Tipo:</dt>
        <dd class="text-gray-700">@(Model.IsPriority ? "⚡ Urgente" : "Normal")</dd>
    </dl>

    <form method="post" style="display:inline;">
        <button type="submit" class="bg-red-600 text-white px-6 py-2 rounded hover:bg-red-700 font-bold">Confirmar Eliminación</button>
    </form>
    <a href="/Tariffs" class="bg-gray-400 text-white px-6 py-2 rounded hover:bg-gray-500 font-bold inline-block">Cancelar</a>
</div>
