@model LogisticaApp.Models.Tariff

@{
    ViewData["Title"] = "Nueva Tarifa";
}

<h2 class="text-3xl font-bold text-gray-800 mb-8">➕ Nueva Tarifa</h2>

<div class="bg-white rounded-lg shadow-md p-6 max-w-2xl">
    <form method="post">
        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Nombre</label>
            <input type="text" name="name" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
        </div>

        <div class="grid grid-cols-2 gap-4 mb-4">
            <div>
                <label class="block text-gray-700 font-bold mb-2">Distancia Mín (km)</label>
                <input type="number" name="minDistance" step="0.01" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
            </div>
            <div>
                <label class="block text-gray-700 font-bold mb-2">Distancia Máx (km)</label>
                <input type="number" name="maxDistance" step="0.01" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4 mb-4">
            <div>
                <label class="block text-gray-700 font-bold mb-2">Precio Base ($)</label>
                <input type="number" name="basePrice" step="0.01" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
            </div>
            <div>
                <label class="block text-gray-700 font-bold mb-2">Precio por kg ($)</label>
                <input type="number" name="pricePerKg" step="0.01" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
            </div>
        </div>

        <div class="mb-4">
            <label class="flex items-center">
                <input type="checkbox" name="isPriority" class="w-4 h-4">
                <span class="ml-2 text-gray-700 font-bold">¿Es prioridad?</span>
            </label>
        </div>

        <div class="mb-4">
            <label class="flex items-center">
                <input type="checkbox" name="isActive" checked class="w-4 h-4">
                <span class="ml-2 text-gray-700 font-bold">Activo</span>
            </label>
        </div>

        <div class="flex gap-4">
            <button type="submit" class="bg-green-600 text-white px-6 py-2 rounded-lg hover:bg-green-700 font-bold">
                ✅ Crear Tarifa
            </button>
            <a href="/Tariffs/Index" class="bg-gray-500 text-white px-6 py-2 rounded-lg hover:bg-gray-600 font-bold">
                Cancelar
            </a>
        </div>
    </form>
</div>
